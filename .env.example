# --- Required / Database ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/wrectifai
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# --- API Server Configurations ---
HOST=0.0.0.0
PORT=3000

# --- CORS Config ---
WEB_ORIGINS=http://localhost:4200,http://localhost:3001

# --- Cookies Config ---
COOKIE_SAME_SITE=lax
# COOKIE_DOMAIN=.yourdomain.com

# --- OAuth Credentials ---
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
APPLE_CLIENT_ID=your-apple-client-id-here
NEXT_PUBLIC_APPLE_CLIENT_ID=your-apple-client-id-here
NEXT_PUBLIC_APPLE_REDIRECT_URI=http://localhost:3001/auth/login

# --- LLM Provider Configurations ---
# Main diagnosis LLM provider: groq | openai
LLM_PROVIDER=groq
LLM_MODEL=openai/gpt-oss-120b
GROQ_API_KEY=your-groq-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# --- Multimodal (Vision / STT) Configurations ---
# Image Analysis (e.g., Groq Vision, reuses GROQ_API_KEY)
IMAGE_LLM_PROVIDER=groq
IMAGE_LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Audio Transcription (e.g., Groq Whisper, reuses GROQ_API_KEY)
AUDIO_PROVIDER=groq
AUDIO_MODEL=whisper-large-v3-turbo

# Note: To use OpenAI instead, set:
# IMAGE_LLM_PROVIDER=openai
# IMAGE_LLM_MODEL=gpt-4o
# AUDIO_PROVIDER=openai
# AUDIO_MODEL=whisper-1
# And ensure OPENAI_API_KEY is populated.
